<div class="section project-header">
    <div class="header-row">
        <div>
            <h1>@(Project?.Name ?? "Untitled Project")</h1>
            @if (!string.IsNullOrEmpty(Project?.Lead))
            {
                <p class="project-lead">Lead: @Project.Lead</p>
            }
        </div>
        <div class="header-meta">
            @if (!string.IsNullOrEmpty(Project?.Status))
            {
                <span class="status-badge status-@GetStatusClass()">@Project.Status</span>
            }
            @if (!string.IsNullOrEmpty(Project?.LastUpdated))
            {
                <span class="last-updated">Updated: @Project.LastUpdated</span>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Project?.Summary))
    {
        <p class="project-summary">@Project.Summary</p>
    }
</div>

@code {
    [Parameter] public ProjectInfo? Project { get; set; }

    private string GetStatusClass()
    {
        return (Project?.Status?.ToLowerInvariant()) switch
        {
            "on track" or "on-track" => "on-track",
            "at risk" or "at-risk" => "at-risk",
            "behind" => "behind",
            _ => "unknown"
        };
    }
}