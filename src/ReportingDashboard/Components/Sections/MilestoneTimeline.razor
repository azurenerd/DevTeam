@if (Milestones.Count > 0)
{
    <div class="section milestone-timeline">
        <h2>Milestone Timeline</h2>
        <div class="timeline-track">
            @foreach (var milestone in Milestones)
            {
                <div class="timeline-item milestone-@GetStatusClass(milestone)">
                    <div class="timeline-marker"></div>
                    <div class="timeline-content">
                        <span class="milestone-title">@milestone.Title</span>
                        @if (!string.IsNullOrEmpty(milestone.TargetDate))
                        {
                            <span class="milestone-date">@milestone.TargetDate</span>
                        }
                        <span class="milestone-status">@milestone.Status</span>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public List<Milestone> Milestones { get; set; } = [];

    private static string GetStatusClass(Milestone m)
    {
        return (m.Status?.ToLowerInvariant()) switch
        {
            "completed" or "complete" => "completed",
            "in progress" or "in-progress" => "in-progress",
            "at risk" or "at-risk" => "at-risk",
            "upcoming" => "upcoming",
            _ => "upcoming"
        };
    }
}