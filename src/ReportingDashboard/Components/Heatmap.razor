<div class="hm-wrap">
    <div class="hm-title">Monthly Execution Heatmap &mdash; Shipped &middot; In Progress &middot; Carryover &middot; Blockers</div>
    <div class="hm-grid" style="grid-template-columns: 160px repeat(@HeatmapModel.Months.Count, 1fr);">
        <div class="hm-corner">STATUS</div>
        @foreach (var month in HeatmapModel.Months)
        {
            var isHighlight = month == HeatmapModel.HighlightMonth;
            <div class="hm-col-hdr @(isHighlight ? "hm-highlight" : "")">@month</div>
        }

        @foreach (var row in HeatmapModel.Rows)
        {
            var style = GetCategoryStyle(row.Category);
            <div class="hm-row-hdr" style="background: @style.HeaderBg; color: @style.HeaderText;">
                @style.Emoji @row.Category.ToUpperInvariant()
            </div>
            @foreach (var month in HeatmapModel.Months)
            {
                var items = row.Items.TryGetValue(month, out var list) ? list : null;
                var isHighlighted = month == HeatmapModel.HighlightMonth;
                var bgColor = isHighlighted ? style.HighlightBg : style.CellBg;
                <HeatmapCell Items="@items" AccentColor="@style.Accent" BgColor="@bgColor" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public HeatmapData HeatmapModel { get; set; } = new();

    private record CategoryStyle(string HeaderBg, string HeaderText, string CellBg, string HighlightBg, string Accent, string Emoji);

    private CategoryStyle GetCategoryStyle(string category) => category switch
    {
        "Shipped" => new("#E8F5E9", "#1B7A28", "#F0FBF0", "#D8F2DA", "#34A853", "✅"),
        "In Progress" => new("#E3F2FD", "#1565C0", "#EEF4FE", "#DAE8FB", "#0078D4", "🔄"),
        "Carryover" => new("#FFF8E1", "#B45309", "#FFFDE7", "#FFF0B0", "#F4B400", "🔁"),
        "Blockers" => new("#FEF2F2", "#991B1B", "#FFF5F5", "#FFE4E4", "#EA4335", "🚫"),
        _ => new("#F5F5F5", "#666", "#FAFAFA", "#F0F0F0", "#999", "•")
    };
}
