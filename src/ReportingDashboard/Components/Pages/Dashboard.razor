@page "/"
@inject IDashboardDataService DataService
@implements IDisposable

@if (DataService.GetError() is string error)
{
    <div class="error-panel">
        <div class="error-icon">⚠</div>
        <div class="error-msg">@error</div>
        <div class="error-hint">Fix the file and save — the dashboard will reload automatically.</div>
    </div>
}
else if (DataService.GetData() is DashboardData data)
{
    <Header Project="@data.Project" />
    <Timeline TimelineModel="@data.Timeline" CurrentDate="@data.Project.CurrentDate" />
    <Heatmap HeatmapModel="@data.Heatmap" />
}

@code {
    protected override void OnInitialized()
    {
        DataService.OnDataChanged += HandleDataChanged;
    }

    private async void HandleDataChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DataService.OnDataChanged -= HandleDataChanged;
    }
}
