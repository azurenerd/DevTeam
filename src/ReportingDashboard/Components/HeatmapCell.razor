<div class="hm-cell" style="background: @BgColor; --accent: @AccentColor;">
    @if (Items == null || Items.Count == 0)
    {
        <div class="it empty">-</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div class="it">@item</div>
        }
    }
</div>

@code {
    [Parameter] public List<string>? Items { get; set; }
    [Parameter] public string AccentColor { get; set; } = "#999";
    [Parameter] public string BgColor { get; set; } = "#FFF";
}
