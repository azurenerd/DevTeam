@using System.Globalization

<div class="tl-area">
    <div class="tl-labels">
        @foreach (var track in TimelineModel.Tracks)
        {
            <div class="tl-label">
                <span class="tl-id" style="color: @track.Color;">@track.Id</span>
                <span class="tl-name">@track.Name</span>
            </div>
        }
    </div>
    <div class="tl-svg-box">
        <svg width="@F(SvgWidth)" height="@F(SvgHeight)" style="overflow: visible;">
            <defs>
                <filter id="sh" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-opacity="0.3" />
                </filter>
            </defs>

            @foreach (var (date, label) in GetMonthGridlines())
            {
                var x = GetX(date);
                <line x1="@F(x)" y1="0" x2="@F(x)" y2="@F(SvgHeight)"
                      stroke="#BBB" stroke-opacity="0.4" stroke-width="1" />
                @SvgText(F(x + 5), "14", "11", "600", "#666", null, label)
            }

            @if (!string.IsNullOrEmpty(CurrentDate) && DateOnly.TryParse(CurrentDate, out var nowDate))
            {
                var nowX = GetX(nowDate);
                <line x1="@F(nowX)" y1="18" x2="@F(nowX)" y2="@F(SvgHeight)"
                      stroke="#EA4335" stroke-width="2" stroke-dasharray="5,3" />
                @SvgText(F(nowX), "14", "10", "bold", "#EA4335", "middle", "NOW")
            }

            @for (var i = 0; i < TimelineModel.Tracks.Count; i++)
            {
                var track = TimelineModel.Tracks[i];
                var y = GetTrackY(i);

                <line x1="0" y1="@F(y)" x2="@F(SvgWidth)" y2="@F(y)"
                      stroke="@track.Color" stroke-width="3" />

                @for (var j = 0; j < track.Milestones.Count; j++)
                {
                    var ms = track.Milestones[j];
                    if (!DateOnly.TryParse(ms.Date, out var msDate)) continue;
                    var mx = GetX(msDate);
                    var above = j % 2 == 0;
                    var labelY = above ? y - 18 : y + 24;

                    @if (ms.Type == "checkpoint")
                    {
                        <circle cx="@F(mx)" cy="@F(y)" r="6"
                                fill="white" stroke="@track.Color" stroke-width="2.5" />
                    }
                    else if (ms.Type == "poc")
                    {
                        <polygon points="@DiamondPoints(mx, y)"
                                 fill="#F4B400" filter="url(#sh)" />
                    }
                    else if (ms.Type == "production")
                    {
                        <polygon points="@DiamondPoints(mx, y)"
                                 fill="#34A853" filter="url(#sh)" />
                    }

                    @SvgText(F(mx), F(labelY), "10", null, "#666", "middle", ms.Label)
                }
            }
        </svg>
    </div>
</div>

@code {
    [Parameter] public TimelineData TimelineModel { get; set; } = new();
    [Parameter] public string CurrentDate { get; set; } = string.Empty;

    private const double SvgWidth = 1560;
    private const double SvgHeight = 185;
    private const double TopPadding = 42;
    private const double BottomPadding = 31;

    private DateOnly _start;
    private DateOnly _end;
    private double _totalDays;

    protected override void OnParametersSet()
    {
        DateOnly.TryParse(TimelineModel.StartDate, out _start);
        DateOnly.TryParse(TimelineModel.EndDate, out _end);
        _totalDays = _end.DayNumber - _start.DayNumber;
    }

    private double GetX(DateOnly date)
    {
        if (_totalDays <= 0) return 0;
        return (double)(date.DayNumber - _start.DayNumber) / _totalDays * SvgWidth;
    }

    private double GetTrackY(int index)
    {
        var count = TimelineModel.Tracks.Count;
        var available = SvgHeight - TopPadding - BottomPadding;
        if (count <= 1) return TopPadding + available / 2.0;
        return TopPadding + (double)index * available / (count - 1);
    }

    private string F(double v) => v.ToString("F1", CultureInfo.InvariantCulture);

    private string DiamondPoints(double cx, double cy, double s = 11)
    {
        return $"{F(cx)},{F(cy - s)} {F(cx + s)},{F(cy)} {F(cx)},{F(cy + s)} {F(cx - s)},{F(cy)}";
    }

    private MarkupString SvgText(string x, string y, string fontSize, string? fontWeight, string fill, string? anchor, string content)
    {
        var fw = fontWeight != null ? $" font-weight=\"{fontWeight}\"" : "";
        var ta = anchor != null ? $" text-anchor=\"{anchor}\"" : "";
        return new MarkupString($"<text x=\"{x}\" y=\"{y}\" font-size=\"{fontSize}\"{fw} fill=\"{fill}\"{ta} font-family=\"Segoe UI, Arial\">{System.Net.WebUtility.HtmlEncode(content)}</text>");
    }
    private IEnumerable<(DateOnly date, string label)> GetMonthGridlines()
    {
        if (_totalDays <= 0) yield break;
        var current = new DateOnly(_start.Year, _start.Month, 1);
        if (current < _start) current = current.AddMonths(1);
        while (current <= _end)
        {
            yield return (current, current.ToString("MMM", CultureInfo.InvariantCulture));
            current = current.AddMonths(1);
        }
    }
}