<div class="hdr">
    <div class="hdr-left">
        <h1>
            @Project.Title
            @if (!string.IsNullOrEmpty(Project.BacklogUrl))
            {
                <a href="@Project.BacklogUrl" target="_blank">📋 ADO Backlog</a>
            }
        </h1>
        <div class="sub">@Project.Subtitle</div>
    </div>
    <div class="legend">
        <div class="legend-item"><span class="diamond poc"></span> PoC Milestone</div>
        <div class="legend-item"><span class="diamond prod"></span> Production Release</div>
        <div class="legend-item"><span class="circle-icon"></span> Checkpoint</div>
        <div class="legend-item"><span class="now-bar"></span> Now</div>
    </div>
</div>

@code {
    [Parameter] public ProjectInfo Project { get; set; } = new();
}
