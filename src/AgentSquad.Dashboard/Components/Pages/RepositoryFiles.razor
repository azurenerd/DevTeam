@page "/repository/files"
@page "/repository/files/{*FilePath}"
@using AgentSquad.Core.DevPlatform.Models
@using AgentSquad.Dashboard.Services
@using Markdig
@inject IDashboardDataService DataService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Virtual Dev Team — Code</PageTitle>

<div class="page-header" data-testid="page-repository-files">
    <h1 class="page-title">💻 Code</h1>
    <div class="header-badges">
        <span class="badge badge-info">@_effectiveBranch</span>
        @if (_fileTree is not null)
        {
            <span class="badge badge-purple">@_fileTree.Files.Count files</span>
        }
    </div>
</div>

@* Tab bar matching Repository.razor style *@
<div class="repo-tab-bar">
    <button class="repo-tab" @onclick="NavigateToRepo">
        🔀 Pull Requests
    </button>
    <button class="repo-tab" @onclick='() => Navigation.NavigateTo("/repository/issues")'>
        📋 Issues
    </button>
    <button class="repo-tab active">
        💻 Code
    </button>
</div>

@if (!_configured)
{
    <div class="files-no-config">
        <div class="files-no-config-icon">⚠️</div>
        <h3>No Repository Configured</h3>
        <p>Configure a repository connection to browse files.</p>
        <a href="/configuration" class="files-config-link">Go to Configuration →</a>
    </div>
}
else if (_loading)
{
    <div class="files-loading">
        <div class="files-spinner"></div>
        <span>Loading repository tree...</span>
    </div>
}
else if (_error is not null)
{
    <div class="files-error">
        <span>❌ @_error</span>
        <button class="files-retry-btn" @onclick="LoadTreeAsync">Retry</button>
    </div>
}
else if (_viewingFile)
{
    @* ── File Content View ── *@
    <div class="files-breadcrumb">
        <a class="files-breadcrumb-link" @onclick="NavigateToRoot" @onclick:preventDefault>@_repoName</a>
        @foreach (var segment in GetPathSegments())
        {
            <span class="files-breadcrumb-sep">/</span>
            @if (segment.IsLast)
            {
                <span class="files-breadcrumb-current">@segment.Name</span>
            }
            else
            {
                <a class="files-breadcrumb-link" @onclick="() => NavigateToPath(segment.FullPath)" @onclick:preventDefault>@segment.Name</a>
            }
        }
    </div>

    @if (_fileContent is null)
    {
        <div class="files-loading"><div class="files-spinner"></div><span>Loading file...</span></div>
    }
    else if (_fileContent.IsBinary)
    {
        <div class="files-binary-notice">
            <span>📦 Binary file — @_fileContent.FileName (@FormatSize(_fileContent.SizeBytes))</span>
        </div>
    }
    else
    {
        <div class="files-content-header">
            <span class="files-content-name">@_fileContent.FileName</span>
            <span class="files-content-size">@FormatSize(_fileContent.SizeBytes)</span>
            @if (_fileContent.WasTruncated)
            {
                <span class="files-content-truncated">⚠️ Truncated (showing first 100KB)</span>
            }
            @if (IsMarkdownFile(_fileContent.FileName) && !_fileContent.WasTruncated)
            {
                <div class="files-view-toggle">
                    <button class="files-toggle-btn @(!_previewMarkdown ? "active" : "")" @onclick="() => _previewMarkdown = false">
                        &lt;/&gt; Code
                    </button>
                    <button class="files-toggle-btn @(_previewMarkdown ? "active" : "")" @onclick="() => _previewMarkdown = true">
                        👁️ Preview
                    </button>
                </div>
            }
        </div>
        @if (_previewMarkdown && IsMarkdownFile(_fileContent.FileName))
        {
            <div class="files-markdown-preview">
                @((MarkupString)RenderMarkdownSafe(_fileContent.Content ?? ""))
            </div>
        }
        else
        {
            <div class="files-content-viewer">
                <table class="files-code-table">
                    @{ var lines = (_fileContent.Content ?? "").Split('\n'); }
                    @for (var i = 0; i < lines.Length; i++)
                    {
                        var lineNum = i + 1;
                        <tr class="files-code-line">
                            <td class="files-line-number">@lineNum</td>
                            <td class="files-line-content"><pre>@lines[i]</pre></td>
                        </tr>
                    }
                </table>
            </div>
        }
    }
}
else
{
    @* ── Directory Listing View ── *@
    <div class="files-breadcrumb">
        @if (string.IsNullOrEmpty(FilePath))
        {
            <span class="files-breadcrumb-current">@_repoName</span>
        }
        else
        {
            <a class="files-breadcrumb-link" @onclick="NavigateToRoot" @onclick:preventDefault>@_repoName</a>
            @foreach (var segment in GetPathSegments())
            {
                <span class="files-breadcrumb-sep">/</span>
                @if (segment.IsLast)
                {
                    <span class="files-breadcrumb-current">@segment.Name</span>
                }
                else
                {
                    <a class="files-breadcrumb-link" @onclick="() => NavigateToPath(segment.FullPath)" @onclick:preventDefault>@segment.Name</a>
                }
            }
        }
    </div>

    <div class="files-table">
        <div class="files-table-header">
            <span>Name</span>
        </div>
        @foreach (var entry in GetCurrentDirectoryEntries())
        {
            <div class="files-table-row" @onclick="() => OnEntryClick(entry)">
                <span class="files-entry-icon">@(entry.IsDirectory ? "📁" : "📄")</span>
                <span class="files-entry-name">@entry.Name</span>
            </div>
        }
        @if (!GetCurrentDirectoryEntries().Any())
        {
            <div class="files-table-empty">No files in this directory</div>
        }
    </div>
}

@code {
    [Parameter] public string? FilePath { get; set; }

    private RepositoryFileTreeResult? _fileTree;
    private RepositoryFileContentResult? _fileContent;
    private string _effectiveBranch = "main";
    private string _repoName = "Repository";
    private bool _loading = true;
    private bool _configured = true;
    private bool _viewingFile;
    private bool _previewMarkdown;
    private string? _error;

    private static readonly MarkdownPipeline _markdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .DisableHtml()
        .Build();

    protected override async Task OnInitializedAsync()
    {
        _repoName = DataService.RepositoryDisplayName;
        if (string.IsNullOrEmpty(_repoName) || _repoName == "Unknown")
        {
            _configured = false;
            _loading = false;
            return;
        }
        // Use just the repo name part
        if (_repoName.Contains('/'))
            _repoName = _repoName.Split('/').Last();

        await LoadTreeAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_fileTree is null) return;
        await DetermineViewMode();
    }

    private async Task LoadTreeAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _fileTree = await DataService.GetRepositoryFileTreeAsync(ct: default);
            _effectiveBranch = _fileTree.Branch;
            await DetermineViewMode();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load file tree: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task DetermineViewMode()
    {
        if (_fileTree is null) return;

        var normalizedPath = NormalizePath(FilePath);

        // Is this a file path? Check if it exists in the tree
        if (!string.IsNullOrEmpty(normalizedPath) &&
            _fileTree.Files.Any(f => string.Equals(f, normalizedPath, StringComparison.OrdinalIgnoreCase) ||
                                    string.Equals(f.Replace('\\', '/'), normalizedPath.Replace('\\', '/'), StringComparison.OrdinalIgnoreCase)))
        {
            _viewingFile = true;
            _fileContent = null;
            _previewMarkdown = IsMarkdownFile(normalizedPath); // Default to preview for .md files
            StateHasChanged();
            _fileContent = await DataService.GetFileContentWithMetadataAsync(normalizedPath, _effectiveBranch);
            StateHasChanged();
        }
        else
        {
            _viewingFile = false;
            _fileContent = null;
            _previewMarkdown = false;
        }
    }

    private IEnumerable<FileEntry> GetCurrentDirectoryEntries()
    {
        if (_fileTree is null) return Enumerable.Empty<FileEntry>();

        var currentDir = NormalizePath(FilePath);
        var prefix = string.IsNullOrEmpty(currentDir) ? "" : currentDir + "/";

        var directories = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var files = new List<FileEntry>();

        foreach (var filePath in _fileTree.Files)
        {
            var normalized = filePath.Replace('\\', '/');
            if (!string.IsNullOrEmpty(prefix) && !normalized.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                continue;

            var relative = string.IsNullOrEmpty(prefix) ? normalized : normalized[prefix.Length..];
            var slashIndex = relative.IndexOf('/');

            if (slashIndex >= 0)
            {
                // This is a subdirectory
                var dirName = relative[..slashIndex];
                directories.Add(dirName);
            }
            else
            {
                // This is a file at this level
                files.Add(new FileEntry { Name = relative, FullPath = normalized, IsDirectory = false });
            }
        }

        // Directories first (sorted), then files (sorted)
        return directories
            .OrderBy(d => d, StringComparer.OrdinalIgnoreCase)
            .Select(d => new FileEntry
            {
                Name = d,
                FullPath = string.IsNullOrEmpty(prefix) ? d : prefix + d,
                IsDirectory = true
            })
            .Concat(files.OrderBy(f => f.Name, StringComparer.OrdinalIgnoreCase));
    }

    private void OnEntryClick(FileEntry entry)
    {
        if (entry.IsDirectory)
        {
            NavigateToPath(entry.FullPath);
        }
        else
        {
            Navigation.NavigateTo($"/repository/files/{entry.FullPath}");
        }
    }

    private void NavigateToRoot() => Navigation.NavigateTo("/repository/files");
    private void NavigateToPath(string path) => Navigation.NavigateTo($"/repository/files/{path}");
    private void NavigateToRepo() => Navigation.NavigateTo("/repository");

    private IEnumerable<PathSegment> GetPathSegments()
    {
        var path = NormalizePath(FilePath);
        if (string.IsNullOrEmpty(path)) yield break;

        var parts = path.Split('/');
        var accumulated = "";
        for (var i = 0; i < parts.Length; i++)
        {
            accumulated = i == 0 ? parts[i] : $"{accumulated}/{parts[i]}";
            yield return new PathSegment
            {
                Name = parts[i],
                FullPath = accumulated,
                IsLast = i == parts.Length - 1
            };
        }
    }

    private static string NormalizePath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return "";
        return path.Replace('\\', '/').TrimStart('/').TrimEnd('/');
    }

    private static string FormatSize(long bytes)
    {
        return bytes switch
        {
            < 1024 => $"{bytes} B",
            < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
            _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
        };
    }

    private static bool IsMarkdownFile(string fileName)
    {
        return fileName.EndsWith(".md", StringComparison.OrdinalIgnoreCase) ||
               fileName.EndsWith(".markdown", StringComparison.OrdinalIgnoreCase) ||
               fileName.EndsWith(".mdx", StringComparison.OrdinalIgnoreCase);
    }

    private static string RenderMarkdownSafe(string markdown)
    {
        return Markdown.ToHtml(markdown, _markdownPipeline);
    }

    public void Dispose() { }

    private record FileEntry
    {
        public required string Name { get; init; }
        public required string FullPath { get; init; }
        public required bool IsDirectory { get; init; }
    }

    private record PathSegment
    {
        public required string Name { get; init; }
        public required string FullPath { get; init; }
        public required bool IsLast { get; init; }
    }
}
