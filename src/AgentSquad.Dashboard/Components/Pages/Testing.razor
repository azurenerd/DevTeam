@page "/testing"
@page "/testing/{Tab}"
@rendermode InteractiveServer
@using AgentSquad.Core.Preview
@using System.Timers
@inject NavigationManager Navigation
@inject ILogger<Testing> Logger
@inject PreviewBuildService PreviewService
@inject TestArtifactIndexService ArtifactService
@implements IDisposable

<PageTitle>Virtual Dev Team — Testing</PageTitle>

<div class="dashboard-header" data-testid="page-testing">
    <h1>🧪 Testing</h1>
    <div class="header-badges">
        @if (_previewStatus?.State == PreviewState.Running)
        {
            <span class="header-badge healthy">● Running</span>
        }
        else if (_previewStatus?.State == PreviewState.Building || _previewStatus?.State == PreviewState.Cloning)
        {
            <span class="header-badge warning">⏳ @_previewStatus.State</span>
        }
        else if (_previewStatus?.State == PreviewState.Failed)
        {
            <span class="header-badge critical">❌ Failed</span>
        }
    </div>
</div>

<!-- Tab navigation -->
<div class="test-tabs">
    <button class="test-tab @(ActiveTab == "preview" ? "active" : "")" @onclick='() => SetTab("preview")'>
        <span class="test-tab-icon">🚀</span> Preview Build
    </button>
    <button class="test-tab @(ActiveTab == "artifacts" ? "active" : "")" @onclick='() => SetTab("artifacts")'>
        <span class="test-tab-icon">📸</span> Test Artifacts
        @if (_artifacts.Count > 0)
        {
            <span class="test-tab-badge">@_artifacts.Count</span>
        }
    </button>
</div>

@if (ActiveTab == "preview")
{
    <!-- Security Warning (first-time only) -->
    @if (!_settings.SecurityWarningAcknowledged && _showSecurityWarning)
    {
        <div class="test-security-warning" data-testid="security-warning">
            <div class="test-warning-icon">⚠️</div>
            <div class="test-warning-content">
                <h3>Security Notice</h3>
                <p>
                    This feature will <strong>clone, build, and execute AI-generated code</strong> on your local machine.
                    While the code is from your configured repository, it has been generated by AI agents and may contain
                    unintended behavior. Run commands will execute with your user permissions.
                </p>
                <div class="test-warning-actions">
                    <button class="btn-primary" @onclick="AcknowledgeSecurity">I understand, proceed</button>
                    <button class="btn-secondary" @onclick="() => _showSecurityWarning = false">Cancel</button>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Preview Build Panel -->
        <div class="test-preview-panel">
            <!-- Branch Info Header -->
            @if (_previewStatus?.BranchName != null)
            {
                <div class="test-branch-info">
                    <span class="test-branch-name">🌿 @_previewStatus.BranchName</span>
                    @if (_previewStatus.HeadCommitSha != null)
                    {
                        <span class="test-commit-sha" title="@_previewStatus.HeadCommitMessage">
                            @_previewStatus.HeadCommitSha
                        </span>
                    }
                    @if (_previewStatus.LastUpdatedUtc != null)
                    {
                        <span class="test-last-updated">
                            Last updated: @_previewStatus.LastUpdatedUtc.Value.ToLocalTime().ToString("g")
                        </span>
                    }
                </div>
            }

            <!-- Settings Form -->
            <div class="test-settings-form">
                <div class="test-field">
                    <label>Clone Directory</label>
                    <input type="text" @bind="_settings.ClonePath" placeholder="C:\projects\my-preview"
                           class="test-input" data-testid="clone-path-input" />
                    <span class="test-field-help">Where to clone/update the working branch</span>
                </div>

                <details class="test-advanced-settings">
                    <summary>Advanced Settings</summary>
                    <div class="test-field">
                        <label>Build Command Override</label>
                        <input type="text" @bind="_settings.BuildCommandOverride"
                               placeholder="(auto-detect from project)"
                               class="test-input" />
                    </div>
                    <div class="test-field">
                        <label>Run Command Override</label>
                        <input type="text" @bind="_settings.RunCommandOverride"
                               placeholder="(auto-detect from project). Use {port} for port placeholder."
                               class="test-input" />
                    </div>
                    <div class="test-field">
                        <label>Port</label>
                        <input type="number" @bind="_settings.Port" min="1024" max="65535"
                               class="test-input test-input-small" />
                        <span class="test-field-help">0 = auto-select a free port</span>
                    </div>
                </details>

                <!-- Action Buttons -->
                <div class="test-actions">
                    @if (_previewStatus?.State == PreviewState.Running)
                    {
                        <button class="btn-danger" @onclick="StopPreview" data-testid="stop-btn">
                            ⏹ Stop
                        </button>
                        @if (_previewStatus.AppUrl != null)
                        {
                            <a href="@_previewStatus.AppUrl" target="_blank" class="btn-primary">
                                🌐 Open App (@_previewStatus.AppUrl)
                            </a>
                        }
                    }
                    else if (_previewStatus?.State == PreviewState.Cloning || _previewStatus?.State == PreviewState.Building)
                    {
                        <button class="btn-warning" @onclick="StopPreview">⏹ Cancel</button>
                        <span class="test-status-text">@_previewStatus.State...</span>
                    }
                    else
                    {
                        var isUpdate = !string.IsNullOrWhiteSpace(_settings.ClonePath) &&
                            Directory.Exists(Path.Combine(_settings.ClonePath, ".git"));
                        <button class="btn-primary" @onclick="StartPreview" data-testid="start-btn"
                                disabled="@string.IsNullOrWhiteSpace(_settings.ClonePath)">
                            @(isUpdate ? "🔄 Update & Run" : "📥 Clone & Run")
                        </button>
                        <button class="btn-secondary" @onclick="SaveSettings">💾 Save Settings</button>
                        @if (_previewStatus?.State == PreviewState.Failed)
                        {
                            <button class="btn-secondary" @onclick="StartPreview">🔁 Retry</button>
                        }
                    }
                </div>
            </div>

            <!-- Terminal Output -->
            <div class="test-terminal" data-testid="terminal-output">
                <div class="test-terminal-header">
                    <span>Output</span>
                    <button class="test-terminal-clear" @onclick="ClearOutput" title="Clear output">🗑</button>
                </div>
                <div class="test-terminal-body" @ref="_terminalRef">
                    @foreach (var line in _outputLines)
                    {
                        <div class="test-terminal-line @GetLineClass(line)">@line</div>
                    }
                    @if (_outputLines.Count == 0)
                    {
                        <div class="test-terminal-line muted">Ready. Configure clone path and click Start.</div>
                    }
                </div>
            </div>

            <!-- Error panel -->
            @if (_previewStatus?.State == PreviewState.Failed && _previewStatus.ErrorMessage != null)
            {
                <div class="test-error-panel">
                    <span class="test-error-icon">❌</span>
                    <div class="test-error-content">
                        <strong>Error:</strong> @_previewStatus.ErrorMessage
                        <div class="test-error-actions">
                            <button class="btn-secondary btn-small" @onclick="StartPreview">🔁 Retry</button>
                            @if (!string.IsNullOrWhiteSpace(_settings.ClonePath))
                            {
                                <button class="btn-secondary btn-small"
                                        @onclick="() => OpenFolder(_settings.ClonePath)">📂 Open Folder</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    <!-- Test Artifacts Tab -->
    <div class="test-artifacts-panel">
        <!-- Filters -->
        <div class="test-artifact-filters">
            <input type="text" @bind="_artifactFilter" @bind:event="oninput"
                   placeholder="Filter by PR, agent name..." class="test-input" />
            <select @bind="_artifactTypeFilter" class="test-select">
                <option value="">All Types</option>
                <option value="Screenshot">Screenshots</option>
                <option value="Video">Videos</option>
                <option value="Trace">Traces</option>
            </select>
            <button class="btn-secondary btn-small" @onclick="RefreshArtifacts">🔄 Refresh</button>
        </div>

        @if (_artifacts.Count == 0)
        {
            <div class="test-empty-state">
                <div class="test-empty-icon">📭</div>
                <h3>No Test Artifacts Yet</h3>
                <p>Test artifacts (screenshots, videos, traces) will appear here as agents run UI tests on PRs.</p>
            </div>
        }
        else
        {
            <!-- Artifact Grid -->
            <div class="test-artifact-grid">
                @foreach (var artifact in GetFilteredArtifacts())
                {
                    <div class="test-artifact-card" data-testid="artifact-@artifact.Id">
                        <div class="test-artifact-preview">
                            @if (artifact.Type == TestArtifactType.Screenshot)
                            {
                                <img src="@artifact.ApiPath" alt="@artifact.FileName" loading="lazy" />
                            }
                            else if (artifact.Type == TestArtifactType.Video)
                            {
                                <video src="@artifact.ApiPath" controls preload="metadata"
                                       style="max-width:100%; max-height:200px;"></video>
                            }
                            else
                            {
                                <div class="test-artifact-icon">🔍</div>
                                <a href="https://trace.playwright.dev" target="_blank" class="test-trace-link">
                                    Open in Trace Viewer
                                </a>
                            }
                        </div>
                        <div class="test-artifact-meta">
                            <span class="test-artifact-name" title="@artifact.FileName">@artifact.FileName</span>
                            <span class="test-artifact-details">
                                @artifact.AgentName
                                @if (artifact.PrNumber != null)
                                {
                                    <text> · PR #@artifact.PrNumber</text>
                                }
                                · @FormatSize(artifact.FileSizeBytes)
                            </span>
                            <span class="test-artifact-date">@artifact.CapturedAtUtc.ToLocalTime().ToString("g")</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string? Tab { get; set; }

    private string ActiveTab => string.IsNullOrWhiteSpace(Tab) ? "preview" : Tab;

    private PreviewSettings _settings = new();
    private PreviewStatus? _previewStatus;
    private List<TestArtifactEntry> _artifacts = [];
    private List<string> _outputLines = [];
    private bool _showSecurityWarning = true;

    private string _artifactFilter = "";
    private string _artifactTypeFilter = "";

    private ElementReference _terminalRef;
    private Timer? _pollTimer;

    protected override async Task OnInitializedAsync()
    {
        _settings = await PreviewService.LoadSettingsAsync();
        _previewStatus = await PreviewService.GetStatusAsync(_settings);
        _artifacts = ArtifactService.GetArtifacts().ToList();

        // Subscribe to output events
        PreviewService.OutputReceived += OnOutputReceived;
        PreviewService.StateChanged += OnStateChanged;

        // Poll for status updates every 3 seconds
        _pollTimer = new Timer(3000);
        _pollTimer.Elapsed += async (_, _) =>
        {
            _previewStatus = await PreviewService.GetStatusAsync(_settings);
            await InvokeAsync(StateHasChanged);
        };
        _pollTimer.Start();
    }

    private void OnOutputReceived(string line)
    {
        _outputLines.Add(line);
        if (_outputLines.Count > 500) _outputLines.RemoveAt(0); // cap at 500 lines
        InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged(PreviewState state)
    {
        InvokeAsync(async () =>
        {
            _previewStatus = await PreviewService.GetStatusAsync(_settings);
            StateHasChanged();
        });
    }

    private async Task SaveSettings()
    {
        try { await PreviewService.SaveSettingsAsync(_settings); }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to save preview settings"); }
    }

    private async Task StartPreview()
    {
        if (!_settings.SecurityWarningAcknowledged)
        {
            _showSecurityWarning = true;
            return;
        }

        _outputLines.Clear();
        await SaveSettings();

        // Start in background to not block the UI
        _ = Task.Run(async () =>
        {
            try { await PreviewService.StartAsync(_settings); }
            catch (Exception ex) { Logger.LogError(ex, "Preview start failed"); }
        });
    }

    private async Task StopPreview()
    {
        PreviewService.Stop();
        _previewStatus = await PreviewService.GetStatusAsync(_settings);
    }

    private async Task AcknowledgeSecurity()
    {
        _settings.SecurityWarningAcknowledged = true;
        _showSecurityWarning = false;
        await SaveSettings();
    }

    private Task RefreshArtifacts()
    {
        _artifacts = ArtifactService.GetArtifacts(forceRefresh: true).ToList();
        return Task.CompletedTask;
    }

    private IEnumerable<TestArtifactEntry> GetFilteredArtifacts()
    {
        var query = _artifacts.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_artifactFilter))
        {
            var filter = _artifactFilter;
            query = query.Where(a =>
                (a.PrNumber != null && a.PrNumber.Contains(filter, StringComparison.OrdinalIgnoreCase)) ||
                a.AgentName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                a.FileName.Contains(filter, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_artifactTypeFilter) &&
            Enum.TryParse<TestArtifactType>(_artifactTypeFilter, out var typeFilter))
        {
            query = query.Where(a => a.Type == typeFilter);
        }

        return query.Take(50);
    }

    private void SetTab(string tab)
    {
        Navigation.NavigateTo($"/testing/{tab}", forceLoad: false);
    }

    private void ClearOutput() => _outputLines.Clear();

    private void OpenFolder(string path)
    {
        _outputLines.Add($"📂 Folder: {path}");
    }

    private static string GetLineClass(string line)
    {
        if (line.StartsWith("✅")) return "success";
        if (line.StartsWith("❌")) return "error";
        if (line.StartsWith("⚠")) return "warning";
        if (line.StartsWith("▶") || line.StartsWith("📥") || line.StartsWith("🔄")) return "info";
        return "";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    public void Dispose()
    {
        PreviewService.OutputReceived -= OnOutputReceived;
        PreviewService.StateChanged -= OnStateChanged;
        _pollTimer?.Stop();
        _pollTimer?.Dispose();
    }
}
